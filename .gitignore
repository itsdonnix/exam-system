# ============================================
# UPLOADS DIRECTORY
# ============================================
# Ignore all files in uploads except .htaccess
uploads/*
!uploads/.htaccess

# Uploads - Image files (explicit exclusions)
uploads/*.jpg
uploads/*.JPG
uploads/*.jpeg
uploads/*.JPEG
uploads/*.png
uploads/*.PNG
uploads/*.gif
uploads/*.GIF
uploads/*.webp
uploads/*.WEBP

# ============================================
# DATABASE FILES
# ============================================
*.sql

# ============================================
# LOG FILES
# ============================================
*.log

# ============================================
# DEPENDENCIES & BUILD DIRECTORIES
# ============================================
/vendor/
node_modules
dist_temp
package-lock.json
