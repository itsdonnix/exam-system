# Uploads directory - ignore all files except .htaccess
!uploads/.htaccess

# But also explicitly ignore common image files in uploads (redundant but clear)
uploads/*.jpg
uploads/*.JPG
uploads/*.jpeg
uploads/*.JPEG
uploads/*.png
uploads/*.PNG
uploads/*.gif
uploads/*.GIF
uploads/*.webp
uploads/*.WEBP

# Database files
*.sql

# Log files
*.log

# Composer dependencies
/vendor/
